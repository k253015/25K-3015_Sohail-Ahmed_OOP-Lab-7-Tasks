class Payment {
    void processPayment() {
        System.out.println("Processing generic payment...");
    }
}

class CreditCard extends Payment {
    void processPayment() {
        System.out.println("Processing Credit Card payment securely.");
    }
}

class DebitCard extends Payment {
    void processPayment() {
        System.out.println("Processing Debit Card payment via bank API.");
    }
}

class PayPal extends Payment {
    void processPayment() {
        System.out.println("Processing PayPal payment via wallet.");
    }
}

public class Main {
    public static void main(String[] args) {
        Payment p;
        p = new CreditCard();
        p.processPayment();
        p = new DebitCard();
        p.processPayment();
        p = new PayPal();
        p.processPayment();
    }
}
