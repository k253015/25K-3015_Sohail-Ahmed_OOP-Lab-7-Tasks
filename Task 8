class SmartDevice {
    void turnOn() {
        System.out.println("Device turning on...");
    }
}

class SmartLight extends SmartDevice {
    void turnOn() {
        System.out.println("Smart Light: LEDs turned on to 75% brightness.");
    }
}

class SmartFan extends SmartDevice {
    void turnOn() {
        System.out.println("Smart Fan: Rotations started at Speed 3.");
    }
}

class SmartAC extends SmartDevice {
    void turnOn() {
        System.out.println("Smart AC: Cooling started at 22 Degrees Celsius.");
    }
}

public class Main {
    public static void main(String[] args) {
        SmartDevice[] devices = { new SmartLight(), new SmartFan(), new SmartAC() };

        for (SmartDevice d : devices) {
            d.turnOn();
        }
    }
}
